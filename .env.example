# =============================================================================
# SMS Platform — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values.
# Variables marked [REQUIRED] must be set before starting the application.
# Variables marked [REQUIRED in production] must be set when NODE_ENV=production.

# --- Database [REQUIRED] ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/sms_app

# --- Redis [REQUIRED] ---
REDIS_URL=redis://localhost:6379

# --- Security Secrets [REQUIRED] ---
# Generate with: openssl rand -base64 32
AUTH_SECRET=
SESSION_SECRET=
INTERNAL_SECRET=

# --- CORS [REQUIRED in production] ---
# The origin URL of console-web (e.g., https://console.example.com)
CORS_ORIGIN=http://localhost:3000

# --- Auth (Keycloak) ---
KEYCLOAK_ISSUER=http://localhost:8080/realms/sms-platform
AUTH_KEYCLOAK_ID=console-web
AUTH_KEYCLOAK_SECRET=
AUTH_KEYCLOAK_ISSUER=http://localhost:8080/realms/sms-platform
AUTH_TRUST_HOST=true
NEXTAUTH_URL=http://localhost:3000

# --- MediaMTX ---
MEDIAMTX_API_USER=admin
MEDIAMTX_API_PASS=admin
ORIGIN_BASE_URL=http://localhost:8888

# --- Deployment ---
# "onprem" enables license checking; "cloud" for SaaS mode
DEPLOYMENT_MODE=onprem

# --- SSL/TLS (production) ---
# Directory containing cert.pem and key.pem for nginx
# SSL_CERT_DIR=./nginx/ssl

# --- License System (On-Prem only) ---
# LICENSE_KEY=eyJpZCI6IkxJQy0yMDI2Li4uIn0.signature...
# LICENSE_PUBLIC_KEY=hex-encoded-public-key
# LICENSE_HEARTBEAT_URL=https://license.vendor.com/api/heartbeat
