{
  "name": "@repo/sdk",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./cameras": {
      "import": "./dist/cameras.js",
      "types": "./dist/cameras.d.ts"
    },
    "./audit": {
      "import": "./dist/audit.js",
      "types": "./dist/audit.d.ts"
    },
    "./playback": {
      "import": "./dist/playback.js",
      "types": "./dist/playback.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@repo/types": "workspace:*"
  },
  "devDependencies": {
    "@repo/config": "workspace:*",
    "typescript": "^5.5.0"
  },
  "keywords": [
    "cctv",
    "streaming",
    "sdk",
    "b2b"
  ],
  "license": "MIT"
}
